# Шаблон окружения Авто-Рилс. Скопировать в .env и подставить значения:
#   cp .env.example .env   &&   отредактировать GROQ_API_KEY
# Перед запуском подгрузить: set -a; source .env; set +a

# --- Обязательно ---
# Groq: транскрипция (Whisper large-v3) И R0-выборка (Qwen chat). Дефолт-провайдер везде.
GROQ_API_KEY=

# --- Необязательно (есть дефолты в config/) ---
# TRANSCRIBE_BACKEND=groq            # groq (дефолт) | faster_whisper
# RENDER_ENCODER=libx264             # libx264 (дефолт) | h264_vaapi | h264_amf
# OPENROUTER_API_KEY=                # R0 failover, M1
